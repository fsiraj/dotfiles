{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMemoryEnabled": true,
  "effortLevel": "high",
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "feedbackSurveyRate": 0,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/home/farzad/.config/claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(* --version)",
      "Bash(* --help *)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/*secret*)",
      "Read(**/*credential*)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/.netrc)",
      "Read(**/.npmrc)",
      "Read(**/.pypirc)",
      "Bash(git push *)"
    ]
  },
  "skipAutoPermissionPrompt": true,
  "statusLine": {
    "command": "bash \"$HOME/.config/claude/statusline.sh\"",
    "type": "command"
  },
  "theme": "auto",
  "tui": "fullscreen"
}
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(* --version)",
      "Bash(* --help *)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/*secret*)",
      "Read(**/*credential*)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/.netrc)",
      "Read(**/.npmrc)",
      "Read(**/.pypirc)",
      "Bash(git push *)"
    ],
    "additionalDirectories": [
      "~/.local/share/nvim/"
    ]
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.config/claude/statusline.sh\""
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  },
  "feedbackSurveyRate": 0,
  "effortLevel": "high",
  "tui": "fullscreen",
  "autoMemoryEnabled": true,
  "theme": "auto",
  "skipAutoPermissionPrompt": true
}
